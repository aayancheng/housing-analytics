{
  "routes": [
    { "src": "/markham-rh", "dest": "/cities/markham-rh/index.html" },
    { "src": "/hong-kong",  "dest": "/cities/hong-kong/index.html"  },
    { "src": "/toronto",    "dest": "/cities/toronto/index.html"    },
    { "src": "/vancouver",  "dest": "/cities/vancouver/index.html"  },
    { "src": "/tokyo",      "dest": "/cities/tokyo/index.html"      }
  ],
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    },
    {
      "source": "/vendor/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/shared/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    }
  ]
}
